# AIRFLOW environment template (§18). Copy to `.env.local` and replace every value.
# `.env.local` is gitignored — never commit real tokens.

# --- Per-actor API tokens (so the board activity log can attribute who did what) ---
# Generate random strings, e.g.:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
TOKEN_HUMAN=replace_me_human
TOKEN_CODEX_BATCH=replace_me_codex
TOKEN_CHATGPT=replace_me_chatgpt
TOKEN_GEMINI=replace_me_gemini

# --- Cloud only (Phase 2, Vercel Blob). Leave blank for local Phase 1. ---
BLOB_READ_WRITE_TOKEN=

# --- Standup / integrations (optional) ---
OBSIDIAN_VAULT_PATH=/Users/YOURNAME/ObsidianVault
BOARD_BASE_URL=http://localhost:3000

# --- Dispatcher (used by dispatcher/run.js) ---
# Which token the dispatcher uses when calling the API (must equal TOKEN_CODEX_BATCH).
DISPATCHER_TOKEN=replace_me_codex
